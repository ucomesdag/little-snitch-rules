{
  "name": "ForkLift",
  "description": "ForkLift - most advanced file manager and FTP client for macOS.",
  "rules": [
    {
      "action": "allow",
      "process": "/Applications/ForkLift.app/Contents/MacOS/ForkLift",
      "remote-domains": [
        "binarynights.com"
      ],
      "ports": "443",
      "protocol": "tcp"
    }
  ]
}
